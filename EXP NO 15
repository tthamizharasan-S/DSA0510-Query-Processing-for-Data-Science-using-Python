import pandas as pd
import numpy as np
data = {
    'A': [1, np.nan, 3, np.nan, 5],
    'B': [np.nan, 2, np.nan, np.nan, 5],
    'C': [1, np.nan, 3, np.nan, np.nan],
    'D': [np.nan, 2, 3, np.nan, np.nan]
}
df = pd.DataFrame(data)
print("Original DataFrame:\n", df)
rows_with_2_or_more_nans = df[df.isna().sum(axis=1) >= 2]
print("\nRows with at least 2 NaN values:\n", rows_with_2_or_more_nans)
