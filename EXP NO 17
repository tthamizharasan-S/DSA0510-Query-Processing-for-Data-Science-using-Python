import pandas as pd
data = {
    'Student': ['Alice', 'Bob', 'Charlie', 'David', 'Eva', 'Frank'],
    'School_Code': ['S001', 'S002', 'S001', 'S003', 'S002', 'S001'],
    'Age': [14, 15, 13, 16, 15, 14]
}
df = pd.DataFrame(data)
print("Original DataFrame:\n", df)
age_stats = df.groupby('School_Code')['Age'].agg(['mean', 'min', 'max'])
print("\nAge statistics for each school:\n", age_stats)
