import pandas as pd
data = {
    'Student': ['Alice', 'Bob', 'Charlie', 'David', 'Eva', 'Frank'],
    'School_Code': ['S001', 'S002', 'S001', 'S003', 'S002', 'S001'],
    'Grade': [85, 90, 78, 92, 88, 95]
}
df = pd.DataFrame(data)
print("Original DataFrame:\n", df)
grouped = df.groupby('School_Code')
print("\nType of GroupBy object:", type(grouped))
for name, group in grouped:
    print(f"\nGroup: {name}")
    print(group)
